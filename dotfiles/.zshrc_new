zsh_plugins=${ZDOTDIR:-~}/.zsh_plugins
[[ -f ${zsh_plugins}.txt ]] || touch ${zsh_plugins}.txt

fpath=(${ZDOTDIR:-~}/.antidote/functions $fpath)
autoload -Uz antidote

if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]]; then
  antidote bundle <${zsh_plugins}.txt >|${zsh_plugins}.zsh
fi

# History Configuration
HISTFILE=~/.zsh_history
HISTSIZE=10000000
SAVEHIST=$HISTSIZE

# Zsh Options
setopt EXTENDED_GLOB
setopt GLOB_DOTS
setopt appendhistory
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT

# FAST: Check typical locations without spawning the 'brew' process
if [[ -d "/opt/homebrew/share/zsh-completions" ]]; then
  FPATH="/opt/homebrew/share/zsh-completions:$FPATH"
elif [[ -d "/usr/local/share/zsh-completions" ]]; then
  FPATH="/usr/local/share/zsh-completions:$FPATH"
elif [[ -d "/home/linuxbrew/.linuxbrew/share/zsh-completions" ]]; then
  FPATH="/home/linuxbrew/.linuxbrew/share/zsh-completions:$FPATH"
fi

fpath=(~/.zfunc $fpath)

autoload -Uz compinit
# Optimization: Check cache once a day (speed up startup by ~100ms)
if [[ -n ${ZDOTDIR}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

source ${zsh_plugins}.zsh

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# LS_COLORS setup with caching for performance (inspired by local/.zshrc)
if [[ ! -f ~/.ls_colors_cache ]]; then
  if command -v vivid >/dev/null; then
    vivid generate ansi > ~/.ls_colors_cache
  fi
fi
[[ -f ~/.ls_colors_cache ]] && export LS_COLORS=$(<~/.ls_colors_cache)

setopt MENU_COMPLETE
zstyle ':omz:update' mode auto
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:*:*' fzf-preview 'less ${(Q)realpath}'
zstyle ':fzf-tab:*' fzf-flags --height=35% --preview-window=right:60%
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/.zcompcache"

# 1) exact match first
# 2) then case-insensitive
# 3) then flex on separators like . _ -
# 4) then substring-ish matching
zstyle ':completion:*' matcher-list \
  '' \
  'm:{a-zA-Z}={A-Za-z}' \
  'r:|[._-]=* r:|=*' \
  'l:|=* r:|=*'

zshaddhistory() {
  setopt LOCAL_OPTIONS
  setopt EXTENDED_GLOB
  print -sr -- "${1%%$'\n'##}"
  fc -p "$HISTFILE"
  return 1
}

bracketed-paste() {
  zle .$WIDGET && LBUFFER=${LBUFFER%$'\n'}
}
zle -N bracketed-paste

autoload -Uz edit-command-line
zle -N edit-command-line

# Key Bindings
# History navigation with FZF
bindkey "$terminfo[kcuu1]" fzf-history-widget
bindkey "$terminfo[kcud1]" fzf-history-widget
bindkey '^[[A' fzf-history-widget
bindkey '^[[B' fzf-history-widget
bindkey '^[OA' fzf-history-widget
bindkey '^[OB' fzf-history-widget
bindkey '^R' fzf-history-widget

# Autosuggest acceptance
bindkey '^ ' autosuggest-accept

# Edit command line
# Insert Mode: Ctrl+v
bindkey -M viins '^v' edit-command-line
# Normal Mode: v (Standard Vi behavior)
bindkey -M vicmd 'v' edit-command-line

TRAPINT() {
  zle && [[ $BUFFER ]] && print -s -- "$BUFFER"
  return $((128 + $1))
}

# Git Aliases
if [[ "$(uname)" == "Darwin" ]]; then
  source /Users/gordonpn/workspace/dotfiles/dotfiles/.git-aliases
elif [[ "$(uname)" == "Linux" ]]; then
  source /home/gordonpn/dotfiles/dotfiles/.git-aliases
fi

# bat — config lives at ~/.config/bat/config (symlinked from .batconfig in dotfiles)
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export BAT_THEME="gruvbox-dark"

# Command Aliases
alias ls='eza -lah --group-directories-first --icons=always'
compdef ls=eza
alias cat='bat'
alias bathelp='bat --plain --language=help'
alias bless='bat --paging=always --style=plain'
alias grep='rg'
alias find='fd'
alias du='dust'
alias df='duf'
alias ps='procs'
alias vi='nvim'
alias vim='nvim'
alias v='nvim'
alias vr='nvim -R'
alias repomix='pnpx repomix@latest'
alias qdrant="docker run --restart always -p 6333:6333 -v qdrant_storage:/qdrant/storage qdrant/qdrant"
alias treee='fd --type f --hidden --exclude .git | tree --fromfile'
alias tree='tree -a -I ".git|node_modules|.venv"'
alias gmi='gemini --skip-trust --approval-mode=yolo'
alias cpt='copilot --effort=xhigh --allow-all'
alias softreboot="osascript -e 'tell app \"System Events\" to restart'"
alias fullreboot='sudo reboot'
alias restartwifi='networksetup -setairportpower en0 off && networksetup -setairportpower en0 on'

# AI/ML Aliases
# Use Flash for speed (Daily Driver)
alias ask="aichat -m deepseek-v4-flash"

# Use Pro for Reasoning (Architectural tasks)
alias reason="llm -m deepseek-v4-pro"

# The "Junior Developer" (Direct file editing)
alias dev="aider --model deepseek/deepseek-v4-pro --architect"

# The "Log Parser" (Unix piping)
alias parse="mods --model deepseek-v4-flash"

# Custom Functions
pnpx() {
  if [ -f "node_modules/.bin/$1" ]; then
    pnpm exec "$@"
  else
    pnpm dlx "$@"
  fi
}

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

if command -v mise >/dev/null; then
  eval "$(mise activate zsh)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
  eval "$($HOME/.local/bin/mise activate zsh)"
fi

# This forces zoxide to intercept the 'cd' command entirely
eval "$(zoxide init zsh --cmd cd)"
eval "$(starship init zsh)"
eval "$(npm completion)"

# Background-fetch the current git repo on cd (rate-limited per repo).
# Lets starship's git_status show ⇣N when behind upstream without manual fetch.
# Override interval (seconds) with GIT_BG_FETCH_INTERVAL (default 600).
autoload -Uz add-zsh-hook
zmodload zsh/datetime 2>/dev/null

_git_bg_fetch() {
  git rev-parse --is-inside-work-tree &>/dev/null || return

  local fetch_head
  fetch_head=$(git rev-parse --git-path FETCH_HEAD 2>/dev/null) || return

  local now=${EPOCHSECONDS:-$(date +%s)} mtime=0
  if [[ -f $fetch_head ]]; then
    mtime=$(date -r "$fetch_head" +%s 2>/dev/null || echo 0)
  fi

  (( now - mtime < ${GIT_BG_FETCH_INTERVAL:-600} )) && return

  GIT_TERMINAL_PROMPT=0 git fetch --quiet --all --prune &>/dev/null &!
}

add-zsh-hook chpwd _git_bg_fetch


# Added by Antigravity CLI installer
export PATH="/Users/gordonpn/.local/bin:$PATH"
