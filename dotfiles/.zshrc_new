zsh_plugins=${ZDOTDIR:-~}/.zsh_plugins
# Ensure ghostty's shell-integration loads in re-invoked shells (exec zsh, sudo -E zsh, etc.).
# Without this, the ssh wrapper that auto-installs xterm-ghostty terminfo on remotes is lost.
if [[ -n $GHOSTTY_RESOURCES_DIR ]]; then
  source "$GHOSTTY_RESOURCES_DIR"/shell-integration/zsh/ghostty-integration
fi

[[ -f ${zsh_plugins}.txt ]] || touch ${zsh_plugins}.txt

fpath=(${ZDOTDIR:-~}/.antidote/functions $fpath)
autoload -Uz antidote

if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]]; then
  antidote bundle <${zsh_plugins}.txt >|${zsh_plugins}.zsh
fi

# History Configuration
HISTFILE=~/.zsh_history
HISTSIZE=10000000
SAVEHIST=$HISTSIZE

# Zsh Options
setopt EXTENDED_GLOB
setopt GLOB_DOTS
export COLORTERM="truecolor"
setopt AUTO_CD
setopt CORRECT
setopt INTERACTIVE_COMMENTS
setopt appendhistory
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt PUSHD_TO_HOME
setopt PUSHD_MINUS

# FAST: Check typical locations without spawning the 'brew' process
if [[ -d "/opt/homebrew/share/zsh-completions" ]]; then
  FPATH="/opt/homebrew/share/zsh-completions:$FPATH"
elif [[ -d "/usr/local/share/zsh-completions" ]]; then
  FPATH="/usr/local/share/zsh-completions:$FPATH"
elif [[ -d "/home/linuxbrew/.linuxbrew/share/zsh-completions" ]]; then
  FPATH="/home/linuxbrew/.linuxbrew/share/zsh-completions:$FPATH"
fi

fpath=(~/.zfunc $fpath)

autoload -Uz compinit
# Optimization: Check cache once a day (speed up startup by ~100ms)
if [[ -n ${ZDOTDIR}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

source ${zsh_plugins}.zsh

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# FZF Configuration
if command -v fzf >/dev/null; then
  # Use fd instead of find
  export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type d --strip-cwd-prefix --hidden --follow --exclude .git'

  # UI Improvements
  export FZF_DEFAULT_OPTS="
    --ansi
    --height 40%
    --border sharp
    --color=bg+:#222121,bg:#181616,spinner:#c8c093,hl:#c4746e \
    --color=fg:#c8c093,header:#c8c093,info:#717c7c,pointer:#7aa89f \
    --color=marker:#7aa89f,fg+:#dcd7ba,prompt:#7aa89f,hl+:#7aa89f
    --prompt='❯ '
    --pointer='▶'
    --marker='✓'
  "

  # CTRL-T: File preview with bat
  export FZF_CTRL_T_OPTS="
    --preview 'bat -n --color=always --colors=\"ui:less\" --line-range :500 {}'
    --bind 'ctrl-/:change-preview-window(down|hidden|)'
    --bind 'ctrl-d:preview-page-down,ctrl-u:preview-page-up'
  "

  # CTRL-R: History search with sorting and keybinds
  if [[ "$(uname)" == "Darwin" ]]; then
    export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:3:hidden:wrap --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort' --header 'Press CTRL-Y to copy command'"
  else
    export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:3:hidden:wrap --bind 'ctrl-y:execute-silent(echo -n {2..} | xclip -sel clip)+abort' --header 'Press CTRL-Y to copy command'"
  fi

  # ALT-C: Directory preview with eza
  export FZF_ALT_C_OPTS="--preview 'eza -T --color=always {} | head -200'"

  # Advanced completions helper functions
  _fzf_compgen_path() {
    fd --hidden --follow --exclude ".git" . "$1"
  }

  _fzf_compgen_dir() {
    fd --type d --hidden --follow --exclude ".git" . "$1"
  }
fi

# LS_COLORS setup with caching for performance (inspired by local/.zshrc)
if [[ ! -f ~/.ls_colors_cache ]]; then
  if command -v vivid >/dev/null; then
    vivid generate ansi > ~/.ls_colors_cache
  fi
fi
[[ -f ~/.ls_colors_cache ]] && export LS_COLORS=$(<~/.ls_colors_cache)

setopt MENU_COMPLETE
zstyle ':omz:update' mode auto
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' verbose yes
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*:functions' ignored-patterns '(_*|pre(cmd|exec))'
zstyle ':completion:*:*:*:*:processes' command "ps -u $USER -o pid,user,comm,cmd -w -w"
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#) ([0-9a-z-]#)*=01;34=0=01'
zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':fzf-tab:complete:kill:argument-rest' extra-opts --preview='ps --pid=$in[(w)1] -o cmd --no-headers -w -w' --preview-window=down:3:wrap
zstyle ':fzf-tab:*' fzf-flags \
  --height=35% \
  --preview-window=right:60% \
  --color='bg+:#222121,bg:#181616,spinner:#c8c093,hl:#c4746e' \
  --color='fg:#c8c093,header:#c8c093,info:#717c7c,pointer:#7aa89f' \
  --color='marker:#7aa89f,fg+:#dcd7ba,prompt:#7aa89f,hl+:#7aa89f' \
  --bind='ctrl-d:preview-page-down,ctrl-u:preview-page-up'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:*:*' fzf-preview '
  if [ -d $realpath ]; then
    eza -1 --color=always $realpath
  else
    bat --color=always --line-range :500 $realpath 2>/dev/null || cat $realpath
  fi'
zstyle ':fzf-tab:complete:(-command-|-parameter-|-brace-parameter-|export|unset|alias):*' fzf-preview 'echo ${(P)word}'
zstyle ':fzf-tab:complete:git-(add|diff|restore):*' fzf-preview 'git diff $word | delta'
zstyle ':fzf-tab:complete:git-log:*' fzf-preview 'git log --color=always $word'
zstyle ':fzf-tab:complete:git-show:*' fzf-preview 'git show --color=always $word | delta'
zstyle ':fzf-tab:complete:git-checkout:*' fzf-preview 'git show --color=always $word | delta'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/.zcompcache"

# 1) exact match first
# 2) then case-insensitive
# 3) then flex on separators like . _ -
# 4) then substring-ish matching
zstyle ':completion:*' matcher-list \
  '' \
  'm:{a-zA-Z}={A-Za-z}' \
  'r:|[._-]=* r:|=*' \
  'l:|=* r:|=*'

zshaddhistory() {
  setopt LOCAL_OPTIONS
  setopt EXTENDED_GLOB
  print -sr -- "${1%%$'\n'##}"
  fc -p "$HISTFILE"
  return 1
}

bracketed-paste() {
  zle .$WIDGET && LBUFFER=${LBUFFER%$'\n'}
}
zle -N bracketed-paste

autoload -Uz edit-command-line
zle -N edit-command-line

# Key Bindings
# History navigation with FZF
bindkey "$terminfo[kcuu1]" fzf-history-widget
bindkey "$terminfo[kcud1]" fzf-history-widget
bindkey '^[[A' fzf-history-widget
bindkey '^[[B' fzf-history-widget
bindkey '^[OA' fzf-history-widget
bindkey '^[OB' fzf-history-widget
bindkey '^R' fzf-history-widget

# Autosuggest acceptance
bindkey '^ ' autosuggest-accept

# Edit command line
# Insert Mode: Ctrl+v
bindkey -M viins '^v' edit-command-line
# Normal Mode: v (Standard Vi behavior)
bindkey -M vicmd 'v' edit-command-line

TRAPINT() {
  zle && [[ $BUFFER ]] && print -s -- "$BUFFER"
  return $((128 + $1))
}

# Git Aliases
if [[ "$(uname)" == "Darwin" ]]; then
  source /Users/gordonpn/workspace/dotfiles/dotfiles/.git-aliases
elif [[ "$(uname)" == "Linux" ]]; then
  source /home/gordonpn/workspace/dotfiles/dotfiles/.git-aliases
fi

# bat — config lives at ~/.config/bat/config (symlinked from .batconfig in dotfiles)
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export BAT_THEME="gruvbox-dark"

# Command Aliases
alias ls='eza -lah --group-directories-first --icons=always'
compdef ls=eza
alias cat='bat'
alias bathelp='bat --plain --language=help'
alias bless='bat --paging=always --style=plain'
alias grep='rg'
alias find='fd'
alias du='dust'
alias df='duf'
alias ps='procs'
# zj: attach to most recent LIVE zellij session, or start fresh if none.
# Skips EXITED sessions (dead-shell remnants from Ctrl+D etc.) — those would
# resurrect as a blank screen. Args are forwarded as-is (e.g. `zj kill-all-sessions`).
zj() {
    if (( $# > 0 )); then
        command zellij "$@"
        return
    fi
    local last
    last=$(command zellij list-sessions -r -n 2>/dev/null \
           | grep -v 'EXITED' \
           | awk 'NR==1 {print $1}')
    if [[ -n $last ]]; then
        command zellij attach "$last"
    else
        command zellij
    fi
}
alias vi='nvim'
alias vim='nvim'
alias v='nvim'
alias vr='nvim -R'
alias repomix='pnpx repomix@latest'
alias qdrant="docker run --restart always -p 6333:6333 -v qdrant_storage:/qdrant/storage qdrant/qdrant"
alias treee='fd --type f --hidden --exclude .git | tree --fromfile'
alias tree='tree -a -I ".git|node_modules|.venv"'
alias gmi='gemini --skip-trust --approval-mode=yolo'
alias agy='agy --continue --dangerously-skip-permissions'
alias cpt='copilot --effort=xhigh --allow-all'
alias fullreboot='sudo reboot'
if [[ "$(uname)" == "Darwin" ]]; then
  alias softreboot="osascript -e 'tell app \"System Events\" to restart'"
  alias restartwifi='networksetup -setairportpower en0 off && networksetup -setairportpower en0 on'
  alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
fi

# AI/ML Aliases
# Use Flash for speed (Daily Driver)
alias ask="aichat -m deepseek-v4-flash"

# Use Pro for Reasoning (Architectural tasks)
alias reason="llm -m deepseek-v4-pro"

# The "Junior Developer" (Direct file editing)
alias dev='aider --model deepseek/deepseek-v4-pro --editor-model deepseek/deepseek-chat --architect --reasoning-effort high --dark-mode --no-attribute-author --no-attribute-committer --no-attribute-commit-message-author --no-attribute-commit-message-committer --no-attribute-co-authored-by --cache-prompts --commit-prompt "write single concern atomic conventional commits"' 

# The "Log Parser" (Unix piping)
alias parse="mods --model deepseek-v4-flash"

# Custom Functions
pnpx() {
  if [ -f "node_modules/.bin/$1" ]; then
    pnpm exec "$@"
  else
    pnpm dlx "$@"
  fi
}

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

if command -v mise >/dev/null; then
  eval "$(mise activate zsh --shims)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
  eval "$($HOME/.local/bin/mise activate zsh --shims)"
fi

# This forces zoxide to intercept the 'cd' command entirely
eval "$(zoxide init zsh --cmd cd)"
eval "$(starship init zsh)"
eval "$(npm completion)"

# Background-fetch the current git repo on cd (rate-limited per repo).
# Lets starship's git_status show ⇣N when behind upstream without manual fetch.
# Override interval (seconds) with GIT_BG_FETCH_INTERVAL (default 600).
autoload -Uz add-zsh-hook
zmodload zsh/datetime 2>/dev/null

_git_bg_fetch() {
  git rev-parse --is-inside-work-tree &>/dev/null || return

  local fetch_head
  fetch_head=$(git rev-parse --git-path FETCH_HEAD 2>/dev/null) || return

  local now=${EPOCHSECONDS:-$(date +%s)} mtime=0
  if [[ -f $fetch_head ]]; then
    mtime=$(date -r "$fetch_head" +%s 2>/dev/null || echo 0)
  fi

  (( now - mtime < ${GIT_BG_FETCH_INTERVAL:-600} )) && return

  GIT_TERMINAL_PROMPT=0 git fetch --quiet --all --prune &>/dev/null &!
}

add-zsh-hook chpwd _git_bg_fetch


# Added by Antigravity CLI installer
export PATH="/Users/gordonpn/.local/bin:$PATH"
