[user]
name = Gordon Pham-Nguyen
email = gordon.pn6@gmail.com

[color]
ui = true

[color "diff"]
whitespace = red reverse

[core]
attributesfile = ~/.gitattributes
autocrlf = input
editor = nvim
eol = lf
excludesfile = ~/.gitignore
pager = delta --paging=auto
safecrlf = true
# hooksPath = ~/.githooks
# pager = diff-so-fancy | less

[pager]
diff = delta
log = delta
reflog = delta
show = delta
difftool = true

[delta]
    features = kanagawa-dragon
    dark = true
    navigate = true
    side-by-side = true
    line-numbers = true
    true-color = always
    hyperlinks = true
    keep-plus-minus-markers = false

[delta "kanagawa-dragon"]
    syntax-theme = Kanagawa
    minus-style = red bold "#2a1f21"
    minus-non-current-style = red bold "#2a1f21"
    minus-emphasized-style = bold red "#432426"
    plus-style = green bold "#1e2b22"
    plus-non-current-style = green bold "#1e2b22"
    plus-emphasized-style = bold green "#2b402d"
    whitespace-error-style = "#c34043" reverse

[delta "decorations"]
commit-decoration-style = bold yellow box ul
file-style = bold yellow ul
file-decoration-style = none
hunk-header-decoration-style = yellow box

[interactive]
diffFilter = delta --color-only

[merge]
conflictStyle = zdiff3
log = true
tool = nvimdiff

[mergetool]
prompt = false
keepBackup = false

[diff]
algorithm = histogram
colorMoved = zebra
colorMovedWS = allow-indentation-change
mnemonicPrefix = true
renames = true
context = 10
indentHeuristic = true
wsErrorHighlight = all
tool = difftastic

[difftool "difftastic"]
cmd = difft "$LOCAL" "$REMOTE"

[format]
pretty = fuller

[log]
date = iso

[tag]
sort = version:refname

[apply]
whitespace = fix

[credential]
helper = osxkeychain

[filter "lfs"]
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process
required = true

[hub]
protocol = https

[url "https://"]
insteadOf = git://

[difftool]
prompt = false

[diff-so-fancy]
changeHunkIndicators = true
markEmptyLines = false
rulerWidth = 80
stripLeadingSymbols = true

[pull]
rebase = true
ff = only

[rebase]
autoStash = true
autosquash = true
updateRefs = true

[rerere]
enabled = true
autoUpdate = true

[commit]
cleanup = strip
verbose = true

[init]
defaultBranch = main

[push]
autoSetupRemote = true
default = simple
followTags = true

[fetch]
prune = true
pruneTags = true
all = true

[branch]
autoSetupMerge = always
sort = -committerdate

[status]
showUntrackedFiles = all

[help]
autocorrect = prompt

