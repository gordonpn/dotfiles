// Default layout — mirrors zellij's stock built-in `default` layout exactly so
// the status-bar plugin shows mode + keybind hints. Verified with:
//   zellij setup --dump-layout default
//
// To opt into a slimmer single-line UI later, replace status-bar with
// `zellij:compact-bar` (mode + session + tabs only, no key hints).
//
// To use the custom kanagawa-dragon zjstatus bar, swap the status-bar pane
// for the commented block at the bottom of this file. Plugin install:
//   wget -O ~/.config/zellij/plugins/zjstatus.wasm \
//     https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm
layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }
    pane
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}

// === Minimal kanagawa-dragon status bar (zjstatus) — uncomment to use ===
